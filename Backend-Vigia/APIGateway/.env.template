# API Gateway environment configuration template
# Copy this file to .env and adjust the values if needed

# =====================
# SERVER
# =====================
SERVER_PORT=8080

# =====================
# KEYCLOAK
# =====================
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/security-realm-dev
KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/security-realm-dev/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID=api-gateway
KEYCLOAK_TOKEN_URL=http://keycloak:8080/realms/security-realm-dev/protocol/openid-connect/token
KEYCLOAK_LOGOUT_URL=http://keycloak:8080/realms/security-realm-dev/protocol/openid-connect/logout
KEYCLOAK_CLIENT_SECRET=change-me-after-configuring-keycloak

# =====================
# JWT
# =====================
JWT_AUDIENCE=http://keycloak:8080/realms/security-realm-dev
