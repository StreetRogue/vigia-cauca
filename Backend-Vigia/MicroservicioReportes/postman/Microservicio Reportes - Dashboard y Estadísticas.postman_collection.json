        {
          "name": "01.6 Estadísticas de Víctimas - Panel Demográfico (FRONT usa esto)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Estructura completa de estadísticas de víctimas', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('totalVictimas');",
                  "    pm.expect(body).to.have.property('porGenero');",
                  "    pm.expect(body).to.have.property('porRangoEdad');",
                  "    pm.expect(body).to.have.property('porGrupoPoblacional');",
                  "    pm.expect(body).to.have.property('filtrosAplicados');",
                  "});",
                  "pm.test('NO existe campo porTipoVictima (fue eliminado)', () => {",
                  "    pm.expect(pm.response.json()).to.not.have.property('porTipoVictima');",
                  "});",
                  "pm.test('totalVictimas es número', () => {",
