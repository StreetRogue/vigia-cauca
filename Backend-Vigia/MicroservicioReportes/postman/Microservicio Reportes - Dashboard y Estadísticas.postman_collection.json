          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('filtrosAplicados contiene anio', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.filtrosAplicados).to.have.property('anio', '{{anio}}');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "X-User-Role", "value": "ADMIN" }],
            "url": {
              "raw": "{{baseUrl}}/estadisticas/resumen?anio={{anio}}",
              "host": ["{{baseUrl}}"],
              "path": ["estadisticas", "resumen"],
              "query": [{ "key": "anio", "value": "{{anio}}" }]
            },
            "description": "Ejemplo: usuario filtra por año. El front manda `anio={{anio}}` a todos los endpoints de la carpeta 01. Este muestra el /resumen."
          },
          "response": []
