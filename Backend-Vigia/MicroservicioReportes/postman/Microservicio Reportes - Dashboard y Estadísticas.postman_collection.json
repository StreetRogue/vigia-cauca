                  "        pm.expect(body.porRangoEdad[0]).to.have.property('frecuenciaRelativa');",
                  "        pm.expect(body.porRangoEdad[0]).to.have.property('frecuenciaAcumulada');",
                  "    }",
                  "});",
                  "pm.test('Frecuencia acumulada de porGenero es monotónica', () => {",
                  "    const body = pm.response.json();",
