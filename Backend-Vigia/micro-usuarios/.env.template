# Micro Usuarios environment configuration template
# Copy this file to .env and adjust the values if needed

# =====================
# SPRING
# =====================
SPRING_PROFILES_ACTIVE=dev
APP_PORT=8081

# =====================
# DATABASE
# =====================
DB_URL=jdbc:postgresql://postgres-usuarios:5432/micro_usuarios
DB_USER=postgres
DB_PASSWORD=postgres

# =====================
# RABBITMQ
# =====================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# =====================
# KEYCLOAK
# =====================
KEYCLOAK_SERVER_URL=http://keycloak:8080
KEYCLOAK_REALM_NAME=security-realm-dev
KEYCLOAK_REALM_MASTER=master
KEYCLOAK_ADMIN_CLI=admin-cli
KEYCLOAK_USER_CONSOLE=admin
KEYCLOAK_CONSOLE_PASSWORD=admin
KEYCLOAK_CLIENT_SECRET=change-me-after-configuring-keycloak
KEYCLOAK_CLIENT_ID=api-gateway
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/security-realm-dev

# =====================
# AUTH (apunta a Keycloak)
# =====================
AUTH0_ISSUER_URI=http://keycloak:8080
AUTH0_CLIENT_ID=api-gateway
AUTH0_CLIENT_SECRET=change-me-after-configuring-keycloak
AUTH0_API_AUDIENCE=http://keycloak:8080/realms/security-realm-dev

# =====================
# ROLES
# =====================
ROL_ADMIN=admin
ROL_OPERADOR=operador
