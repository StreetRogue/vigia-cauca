# API Gateway (todos los microservicios van por aquí en producción/Docker)
VITE_API_GATEWAY_URL=http://localhost:8080

# URLs directas para desarrollo local sin Docker
VITE_API_NOVEDADES_URL=http://localhost:5003
VITE_API_REPORTES_URL=http://localhost:5004
VITE_API_UBICACIONES_URL=http://localhost:8082

# Usar gateway o servicios directos: "gateway" | "direct"
VITE_API_MODE=direct
