      "item": [
        {
          "name": "01.1 Dashboard Completo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Respuesta es objeto JSON', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('object');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Role",
                "value": "ADMIN"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/estadisticas/dashboard?anio={{anio}}",
              "host": ["{{baseUrl}}"],
              "path": ["estadisticas", "dashboard"],
              "query": [
                { "key": "anio", "value": "{{anio}}" }
              ]
            },
            "description": "Retorna todos los datos del dashboard en un solo JSON."
          },
          "response": []
        },
