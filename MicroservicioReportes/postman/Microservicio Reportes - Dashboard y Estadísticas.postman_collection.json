    {
      "name": "02 - Documentos y Reportes",
      "item": [
        {
          "name": "02.1 Previsualizar Reporte (Tabla)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Respuesta es array de novedades', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('array');",
                  "});",
                  "pm.test('Cada novedad tiene novedadId', () => {",
                  "    const body = pm.response.json();",
                  "    if (body.length > 0) {",
                  "        pm.expect(body[0]).to.have.property('novedadId');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Role",
                "value": "ADMIN"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/documentos/previsualizar?anio={{anio}}",
              "host": ["{{baseUrl}}"],
              "path": ["documentos", "previsualizar"],
              "query": [
                { "key": "anio", "value": "{{anio}}" },
                { "key": "municipio", "value": "Popayan", "disabled": true },
                { "key": "categoria", "value": "HOMICIDIO", "disabled": true }
              ]
            },
            "description": "Previsualiza en JSON las novedades que se exportarían al Excel con los filtros dados."
          },
          "response": []
        },
        {
          "name": "02.1b Previsualizar como Visitante (solo PUBLICA)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Visitante solo ve novedades públicas', () => {",
