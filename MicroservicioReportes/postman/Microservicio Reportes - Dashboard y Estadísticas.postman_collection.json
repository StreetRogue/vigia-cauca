    {
      "name": "03 - SSE (Tiempo Real)",
      "item": [
        {
          "name": "03.1 Abrir Stream SSE",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 o 204', () => {",
                  "    pm.expect([200, 204]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Content-Type es text/event-stream', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('text/event-stream');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "text/event-stream"
              },
              {
                "key": "X-User-Role",
                "value": "ADMIN"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/sse/stream?canal=dashboard",
              "host": ["{{baseUrl}}"],
              "path": ["sse", "stream"],
              "query": [
                { "key": "canal", "value": "dashboard" }
              ]
            },
            "description": "Abre una conexión SSE al canal 'dashboard'. En Postman la respuesta se verá como stream de texto. Usar con cliente SSE para producción."
          },
          "response": []
        },
