                { "key": "fechaInicio", "value": "2026-01-01" },
                { "key": "fechaFin", "value": "2026-12-31" }
              ]
            },
            "description": "Descarga el reporte como archivo .xlsx con los filtros aplicados. Guarda la respuesta como archivo binario."
