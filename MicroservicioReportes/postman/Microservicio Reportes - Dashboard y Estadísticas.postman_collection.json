            "url": {
              "raw": "{{baseUrl}}/documentos/previsualizar?anio={{anio}}",
              "host": ["{{baseUrl}}"],
              "path": ["documentos", "previsualizar"],
              "query": [
                { "key": "anio", "value": "{{anio}}" }
              ]
            },
            "description": "Visitante solo puede ver novedades con nivelVisibilidad=PUBLICA."
          },
          "response": []
        },
        {
          "name": "02.2 Descargar Reporte Excel",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type es Excel', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('spreadsheetml');",
                  "});",
                  "pm.test('Content-Disposition presente', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Disposition')).to.include('attachment');",
                  "});"
                ],
                "type": "text/javascript"
